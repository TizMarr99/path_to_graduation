# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key-here
# OR (fallback)
VITE_SUPABASE_ANON_KEY=your-public-anon-key-here

# Optional: Enable dev tools in production
# VITE_ENABLE_DEV_TOOLS=true

# Resend Email Service Configuration
# Required for sending emails via API endpoints
RESEND_API_KEY=re_your_resend_api_key_here

# Email sender configuration
# Default sender email address (must be verified in Resend)
RESEND_FROM_EMAIL=andrea@mostra-ombre.it

# Default sender name
RESEND_FROM_NAME=Andrea

# Optional: Test email address for development
# If set, all emails will be sent to this address instead of the player's email
# Useful for testing without affecting real users
# TEST_EMAIL=test@example.com

# Optional: API base URL for client-side API calls
# Leave empty for same-origin API calls (default for Vercel)
# VITE_API_BASE_URL=

# Optional: public base URL used inside email templates for absolute asset links
# VITE_BASE_URL=https://path-to-graduation.vercel.app
