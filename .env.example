# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key-here
# OR (fallback)
VITE_SUPABASE_ANON_KEY=your-public-anon-key-here

# Optional: Enable dev tools in production
# VITE_ENABLE_DEV_TOOLS=true

# Resend Email Service Configuration
# Required for sending emails via API endpoints
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Email sender configuration
# IMPORTANT: This email address MUST be verified in Resend
# For custom domains (like mostra-ombre.org):
#   1. Add your domain in Resend dashboard: https://resend.com/domains
#   2. Add the DNS records provided by Resend to your Cloudflare DNS settings
#   3. Wait for DNS verification (can take a few minutes to 24 hours)
#   4. Use an email address from your verified domain (e.g., andrea@mostra-ombre.org)
#
# Common Error 550: This occurs when the sender domain is not verified in Resend
# If you get error 500/550, check:
#   - RESEND_API_KEY is set correctly
#   - Domain is verified in Resend (check DNS records in Cloudflare)
#   - Email address uses the verified domain
RESEND_FROM_EMAIL=andrea@mostra-ombre.org

# Default sender name (appears in the "From" field)
RESEND_FROM_NAME=Andrea Sachs

# Optional: Test email address for development
# If set, all emails will be sent to this address instead of the player's email
# Useful for testing without affecting real users
# TEST_EMAIL=test@example.com

# Optional: API base URL for client-side API calls
# Leave empty for same-origin API calls (default for Vercel)
# VITE_API_BASE_URL=

# Optional: public base URL used inside email templates for absolute asset links
# VITE_BASE_URL=https://path-to-graduation.vercel.app
